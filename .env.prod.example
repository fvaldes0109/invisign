# Copy this file to .env on wol-server and fill in real values.
# This file is read by docker-compose.prod.yaml for variable substitution.

# --- Database (shared between compose and laravel .env.prod) ---
DB_ROOT_PASSWORD=change-me-root
DB_DATABASE=image_watermark
DB_USERNAME=app_user
DB_PASSWORD=change-me

# --- Domain (used by nginx template) ---
# Set to your actual domain, e.g. example.com
# nginx will serve app.DOMAIN, api.DOMAIN, and marking.DOMAIN
DOMAIN=your-domain.com

# --- Frontend build args (baked into the React bundle at image build time) ---
VITE_APP_URL=https://your-domain.com
VITE_BACKEND_HOST=https://api.your-domain.com
VITE_BACKEND_PORT=443
VITE_WATERMARK_SERVICE_HOST=https://marking.your-domain.com
VITE_WATERMARK_SERVICE_PORT=443
