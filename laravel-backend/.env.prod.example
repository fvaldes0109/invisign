# Copy this file to laravel-backend/.env.prod on wol-server and fill in real values.

APP_NAME="Image Watermark"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=image_watermark
DB_USERNAME=app_user
DB_PASSWORD=change-me

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=app.your-domain.com
SESSION_DOMAIN=.your-domain.com
